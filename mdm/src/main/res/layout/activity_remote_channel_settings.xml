<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/mdm_background"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_toolbar"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIconTint="@color/mdm_text_primary"
                app:title="远程连接"
                app:titleTextAppearance="@style/TextAppearance.Mdm.Title"
                app:titleTextColor="@color/mdm_text_primary" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/activity_horizontal_margin"
            android:paddingVertical="@dimen/activity_vertical_margin"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 当前使用的连接方式（互斥） -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="连接方式"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="仅能同时启用一种远程连接；切换后其他通道会断开。下方仅展示当前所选通道的配置。"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_connection_mode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_telegram"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telegram" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_feishu"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="飞书" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_clawbot"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ClawBot" />

                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 仅展示当前选中通道的配置（与上方 Chip 联动） -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_telegram_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Telegram 配置"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_primary" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Telegram Bot Token"
                            app:boxStrokeColor="@color/mdm_primary"
                            app:endIconMode="password_toggle"
                            app:hintTextColor="@color/mdm_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTgToken"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/mdm_text_primary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="Telegram Allowed Chat ID (0 = 不限制)"
                            app:boxStrokeColor="@color/mdm_primary"
                            app:hintTextColor="@color/mdm_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTgChatId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberSigned"
                                android:textColor="@color/mdm_text_primary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestTg"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="测试 Telegram Bot"
                            app:strokeColor="@color/mdm_primary" />

                        <TextView
                            android:id="@+id/tvTgTestResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Mdm.Caption"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_clawbot_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ClawBot（微信）"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_secondary" />

                        <TextView
                            android:id="@+id/tvClawBotStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary"
                            tools:text="桥接: 未配置 · 登录: 未配置" />

                        <ImageView
                            android:id="@+id/ivClawBotQr"
                            android:layout_width="240dp"
                            android:layout_height="240dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:contentDescription="ClawBot 登录二维码"
                            android:scaleType="fitCenter"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvClawBotQrHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:textAppearance="@style/TextAppearance.Mdm.Caption"
                            android:textColor="@color/mdm_text_secondary"
                            android:visibility="gone"
                            tools:text="请使用微信「ClawBot 插件」扫描上方二维码" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClawBotLogin"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:text="扫码登录"
                                app:strokeColor="@color/mdm_secondary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClawBotClearAuth"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:text="清除登录"
                                app:strokeColor="@color/mdm_error" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvClawBotResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Mdm.Caption"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_feishu_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="飞书配置"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_tertiary" />

                        <TextView
                            android:id="@+id/tvFeishuStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary"
                            tools:text="状态: 未配置" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="飞书 App ID"
                            app:boxStrokeColor="@color/mdm_tertiary"
                            app:hintTextColor="@color/mdm_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFeishuAppId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/mdm_text_primary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="飞书 App Secret"
                            app:boxStrokeColor="@color/mdm_tertiary"
                            app:endIconMode="password_toggle"
                            app:hintTextColor="@color/mdm_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFeishuAppSecret"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/mdm_text_primary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTestFeishu"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="测试飞书连接"
                            app:strokeColor="@color/mdm_tertiary" />

                        <TextView
                            android:id="@+id/tvFeishuTestResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Mdm.Caption"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 底部留白 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- 底部保存按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="bottom"
            android:layout_margin="16dp"
            android:text="保存"
            android:textSize="16sp"
            app:backgroundTint="@color/mdm_primary"
            app:cornerRadius="@dimen/radius_md" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>