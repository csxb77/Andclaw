<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/mdm_background"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_toolbar"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIconTint="@color/mdm_text_primary"
                app:title="Andclaw"
                app:titleTextAppearance="@style/TextAppearance.Mdm.Title"
                app:titleTextColor="@color/mdm_text_primary" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/activity_horizontal_margin"
            android:paddingVertical="@dimen/activity_vertical_margin"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/device_owner_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/device_owner_root"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设备管理员模式"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_primary" />

                        <TextView
                            android:id="@+id/device_owner_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="未开启"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/setup_device_owner"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_md"
                                android:text="设置设备管理员"
                                android:visibility="gone"
                                app:strokeColor="@color/mdm_primary" />
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/network_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="网络连接"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_primary" />

                        <TextView
                            android:id="@+id/network_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="未连接"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/setup_network"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="设置网络"
                            android:visibility="gone"
                            app:strokeColor="@color/mdm_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/remote_channel_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="远程连接"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="仅能同时启用一种连接方式，切换后其他通道会断开。"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_remote_channel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_telegram"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telegram" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_feishu"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="飞书" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_clawbot"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ClawBot" />

                        </com.google.android.material.chip.ChipGroup>

                        <TextView
                            android:id="@+id/remote_channel_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary"
                            tools:text="未配置" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/setup_remote_channel"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="去配置"
                            app:strokeColor="@color/mdm_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/activity_vertical_margin"
                    app:cardBackgroundColor="@color/mdm_card_background"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/mdm_card_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="对话记录"
                            android:textAppearance="@style/TextAppearance.Mdm.Title"
                            android:textColor="@color/mdm_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="仅展示历史记录，不支持输入。请用已配置的远程连接（Telegram / 飞书 / ClawBot）发送指令，在此查看 AI 的回复与操作。"
                            android:textAppearance="@style/TextAppearance.Mdm.Body"
                            android:textColor="@color/mdm_text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/open_chat_activity"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="对话记录"
                            app:strokeColor="@color/mdm_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/open_test_activity"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="Action Test"
                            app:strokeColor="@color/mdm_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/open_ai_settings"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="AI 设置"
                            app:strokeColor="@color/mdm_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>
