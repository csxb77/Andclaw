<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许 http:// 明文请求（与 https 并存）；仅调试或内网 API 时常用 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
